<Window x:Class="TaskMesh.Master.Views.AddProblemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Problem" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Problem Title:" FontWeight="Bold" Foreground="#34495E"/>
            <TextBox x:Name="TitleBox" Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="Problem Description:" FontWeight="Bold" Foreground="#34495E"/>
            <TextBox x:Name="DescriptionBox" Height="80" 
                     AcceptsReturn="True" TextWrapping="Wrap" 
                     Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="Input Test Cases (one per line):" FontWeight="Bold" Foreground="#34495E"/>
            <TextBox x:Name="InputBox" Height="60" 
                     AcceptsReturn="True" Margin="0,5,0,15" Padding="5" 
                     FontFamily="Consolas" ToolTip="Example: 5 10"/>

            <TextBlock Text="Expected Outputs (one per line):" FontWeight="Bold" Foreground="#34495E"/>
            <TextBox x:Name="OutputBox" Height="60" 
                     AcceptsReturn="True" Margin="0,5,0,15" Padding="5" 
                     FontFamily="Consolas" ToolTip="Example: 15"/>

            <TextBlock Text="Time Limit (seconds):" FontWeight="Bold" Foreground="#34495E"/>
            <TextBox x:Name="TimeLimitBox" Text="5" Margin="0,5,0,20" Padding="5" Width="50" HorizontalAlignment="Left"/>

            <Button Content="ADD TO DISPATCHER" Click="AddButton_Click"
                    Background="#27AE60" Foreground="White" 
                    Height="40" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </ScrollViewer>
</Window>