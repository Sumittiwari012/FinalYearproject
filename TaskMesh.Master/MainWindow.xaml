<Window x:Class="TaskMesh.Master.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:TaskMesh.Master.ViewModels"
        Title="TaskMesh Master" Height="700" Width="1200"
        xmlns:helper="clr-namespace:TaskMesh.Master.Helper">
    <Window.Resources>
        <helper:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2C3E50">
            <TextBox x:Name="PeerIpBox" Width="120" Height="28"
         Margin="5,0" VerticalContentAlignment="Center"
         Text="192.168.1.x"/>
            <Button Content="+ ADD PEER" Click="AddPeer_Click"
        Width="90" Height="28" Margin="5,0"
        Background="#E67E22" Foreground="White" FontWeight="Bold"/>
            <Button Content="▶ START SESSION" Command="{Binding StartSessionCommand}"
        Width="130" Height="30" Margin="10,0"
        Background="#8E44AD" Foreground="White" FontWeight="Bold"/>

            <TextBlock Text="TaskMesh Master" Foreground="White"
                       FontSize="20" Margin="20,0,20,0" VerticalAlignment="Center"/>
            <Button Content="START SERVER" Command="{Binding StartServerCommand}"
                    IsEnabled="{Binding CanStartServer}"
                    Width="120" Height="30" Margin="10,0"
                    Background="#27AE60" Foreground="White" FontWeight="Bold"/>
            <TextBlock Text="{Binding ServerStatus}" Foreground="#BDC3C7"
                       VerticalAlignment="Center" FontStyle="Italic" Margin="10,0"/>
        </StackPanel>

        <!-- MAIN — split 50/50 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Left: Students + Problems -->
                <ColumnDefinition Width="*"/>
                <!-- Right: Scoreboard -->
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- STUDENTS -->
                <DockPanel Grid.Column="0" Background="#ECF0F1">
                    <TextBlock Text="STUDENTS" FontWeight="Bold" Margin="10"
                               FontSize="14" DockPanel.Dock="Top" Foreground="#34495E"/>
                    <ListBox ItemsSource="{Binding Workers}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#BDC3C7" BorderThickness="0,0,0,1" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding WorkerName}"
                                                   FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding WorkerId}"
                                                   FontSize="10" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding IpAddress}"
                                                   FontSize="11" Foreground="#7F8C8D"/>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="{x:Static viewmodels:WorkerStatus.Online}">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="{x:Static viewmodels:WorkerStatus.Offline}">
                                                            <Setter Property="Foreground" Value="Red"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- PROBLEMS -->
                <DockPanel Grid.Column="1">
                    <Button DockPanel.Dock="Top" Content="+ ADD NEW PROBLEM"
                            Command="{Binding AddProblemCommand}"
                            Margin="10" Height="35" Background="#2980B9"
                            Foreground="White" FontWeight="Bold"/>

                    <Border DockPanel.Dock="Bottom" Height="150"
                            Background="#F8F9FA"
                            BorderBrush="#BDC3C7" BorderThickness="0,1,0,0"
                            Visibility="{Binding SelectedProblem,
                                Converter={StaticResource NullToVisibilityConverter}}">
                        <ScrollViewer Margin="10">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedProblem.ProblemName}"
                                           FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>
                                <TextBlock Text="{Binding SelectedProblem.ProblemDescription}"
                                           TextWrapping="Wrap" Foreground="#34495E" Margin="0,5"/>
                                <TextBlock Text="Input:" FontWeight="Bold" Foreground="#7F8C8D"/>
                                <ItemsControl ItemsSource="{Binding SelectedProblem.InputTestCases}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas"
                                                       Foreground="#27AE60"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Expected:" FontWeight="Bold"
                                           Foreground="#7F8C8D" Margin="0,5,0,0"/>
                                <ItemsControl ItemsSource="{Binding SelectedProblem.ExpectedOutputTestCases}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas"
                                                       Foreground="#E74C3C"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <ListBox ItemsSource="{Binding Problems}"
                             SelectedItem="{Binding SelectedProblem}"
                             Margin="10,0,10,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProblemName}"
                                                   FontWeight="Bold" FontSize="14"/>
                                        <ProgressBar Height="8" Margin="0,5"
                                                     Value="{Binding TestCasePassCount}"
                                                     Maximum="{Binding TotalTestCaseCount}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Status}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Grid>

            <!-- RIGHT SIDE — SCOREBOARD -->
            <Grid Grid.Column="1" Background="#2C3E50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="SCOREBOARD"
                           Foreground="White" FontWeight="Bold"
                           FontSize="18" Margin="10,5"/>

                <DataGrid x:Name="ScoreboardGrid"
                          Grid.Row="1"
                          ItemsSource="{Binding Scoreboard}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="DimGray"
                          Foreground="Black"
                          BorderThickness="0"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="#455A64"
                          VerticalGridLinesBrush="#455A64"
                          ColumnHeaderHeight="30">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#2C3E50"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFlagged}" Value="True">
                                    <Setter Property="Background" Value="#C0392B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                            Binding="{Binding WorkerId}"
                            Width="80"/>
                        <DataGridTextColumn Header="Name"
                            Binding="{Binding StudentName}"
                            Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>