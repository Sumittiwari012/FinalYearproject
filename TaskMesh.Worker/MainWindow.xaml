<Window x:Class="TaskMesh.Worker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
        Title="TaskMesh Worker - Code Editor" Height="600" Width="900">

    

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#34495E">
            

            

            <TextBlock Text="{Binding ConnectionStatus}" Foreground="#BDC3C7" 
                       VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="250"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Background="#ECF0F1">
                    <TextBlock Text="ASSIGNED PROBLEMS" DockPanel.Dock="Top"
                               FontWeight="Bold" Margin="10,10,10,5" Foreground="#2C3E50"/>
                    <ListBox ItemsSource="{Binding Problems}"
                             SelectedItem="{Binding SelectedProblem}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProblemName}"
                                           FontWeight="Bold" Padding="10,8"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <Border Grid.Row="1" Background="White" 
                        BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
                    <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedProblem.ProblemName}"
                                       FontWeight="Bold" FontSize="14"
                                       Foreground="#2C3E50" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedProblem.ProblemDescription}"
                                       Margin="0,5,0,8" TextWrapping="Wrap"
                                       Foreground="#34495E" FontSize="12"/>

                            <TextBlock Text="Sample Input:" FontWeight="Bold"
                                       Foreground="#7F8C8D" FontSize="11"/>
                            <ItemsControl ItemsSource="{Binding SelectedProblem.InputTestCases}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Consolas"
                                                   Foreground="#27AE60" Margin="5,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Expected Output:" FontWeight="Bold"
                                       Foreground="#7F8C8D" Margin="0,8,0,0" FontSize="11"/>
                            <ItemsControl ItemsSource="{Binding SelectedProblem.ExpectedOutputTestCases}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Consolas"
                                                   Foreground="#E74C3C" Margin="5,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Column="1" Background="#FFFFFF">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="JAVA CODE EDITOR" Margin="10,5" FontWeight="Bold" Foreground="#7F8C8D"/>

                <TextBox Grid.Row="1" Text="{Binding CurrentCode, UpdateSourceTrigger=PropertyChanged}" 
                         AcceptsReturn="True" AcceptsTab="True"
                         FontFamily="Consolas" FontSize="14"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         Padding="10" BorderThickness="0,1,0,1"/>

                <Button Grid.Row="2" Content="SUBMIT SOLUTION" 
                        Command="{Binding SubmitSolutionCommand}"
                        Height="40" Margin="10" Background="#27AE60" 
                        Foreground="White" FontWeight="Bold"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Background="#2C3E50">
            <StackPanel Margin="15">
                <TextBlock Text="EXECUTION FEEDBACK" Foreground="#95A5A6" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding ResultLog}" Foreground="White" 
                           FontSize="16" FontFamily="Consolas" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>