<Window x:Class="TaskMesh.Worker.Views.WorkerLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskMesh — Join Network" Height="515" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="30">
        <TextBlock Text="TaskMesh Student Account" FontSize="20" FontWeight="Bold"
                   Foreground="#2C3E50" HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

        <TextBlock Text=" ID:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="WorkerIdBox" Height="30" Margin="0,0,0,10" 
                 Padding="5" FontSize="14"/>

        <TextBlock Text="Your Name:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="NameBox" Height="30" Margin="0,0,0,10" 
                 Padding="5" FontSize="14"/>

        <TextBlock Text="Master IP:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="MasterIpBox" Text="127.0.0.1" Height="30"
                 Margin="0,0,0,20" Padding="5" FontSize="14"/>

        <Button Content="JOIN NETWORK" Click="JoinButton_Click"
                Height="40" Background="#2980B9" Foreground="White"
                FontWeight="Bold" FontSize="14"/>
    </StackPanel>
</Window>